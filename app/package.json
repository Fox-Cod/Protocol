{
  "name": "protokol",
  "version": "1.0.0",
  "description": "Протокол — справочник по законам Majestic RP",
  "main": "main.js",
  "author": "Stan Laker",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder --win --x64"
  },
  "build": {
    "appId": "com.stanlaker.protokol",
    "productName": "Protocol",
    "icon": "icon.ico",
    "files": [
      "main.js",
      "preload.js",
      "GovHelper.html",
      "sticker.html",
      "icon.png",
      "icon.ico"
    ],
    "win": {
      "target": "portable",
      "icon": "icon.ico"
    },
    "portable": {
      "artifactName": "Protocol.exe"
    }
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1"
  }
}